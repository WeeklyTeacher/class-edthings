---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

import { getSiteSettings } from '../lib/content';

const {
	title,
	description = "Mr. Sayers' 3rd Grade Class at Eshelman Elementary School.",
} = Astro.props;

const settings = await getSiteSettings();

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/announcements', label: 'Announcements' },
	{ href: '/homework', label: 'Homework' },
	{ href: '/calendar', label: 'Calendar' },
	{ href: '/resources', label: 'Resources' },
	{ href: '/about', label: 'About Mr. Sayers' },
	{ href: '/contact', label: 'Contact' },
	{ href: '/family-documents', label: 'Family Documents' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title} | {settings.websiteName || "Mr. Sayers' Classroom Website"}</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<header class="site-header">
			<div class="shell header-shell">
				<div class="brand-lockup">
					<span class="brand-mark">MS</span>
					<div>
						<p class="eyebrow">{settings.schoolName || 'Eshelman Elementary School'}</p>
						<h1>{settings.websiteName || "Mr. Sayers' Classroom Website"}</h1>
						<p class="brand-subline">{settings.classroomName || "Mr. Sayers' 3rd Grade Class"}</p>
					</div>
				</div>
				<nav class="site-nav" aria-label="Primary">
					{navItems.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</nav>
			</div>
		</header>
		<main id="main" class="page-shell">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="shell footer-shell">
				<p>{settings.contactNote || 'Please check the Contact page for the best way to reach the classroom.'}</p>
				<p>
					{settings.schoolName || 'Eshelman Elementary School'} · {settings.schoolYear || '2026-2027'} · Built for families and a simple
					editing workflow in Keystatic.
				</p>
			</div>
		</footer>
	</body>
</html>
