---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Calendar" description="Placeholder classroom calendar page.">
	<section class="panel section prose">
		<p class="eyebrow">Calendar</p>
		<h2 class="page-title">Class calendar placeholder</h2>
		<p class="page-intro">
			This area is ready for future dates, events, and special classroom reminders. For now, it stays as a simple placeholder
			so the site structure is already in place.
		</p>
		<div class="grid cards">
			<article class="card">
				<h4>Monday</h4>
				<p>Reading workshop, shared writing, and class meeting.</p>
			</article>
			<article class="card">
				<h4>Wednesday</h4>
				<p>Small-group math practice and project time.</p>
			</article>
			<article class="card">
				<h4>Friday</h4>
				<p>Weekly reflection and take-home folder check.</p>
			</article>
		</div>
	</section>
</BaseLayout>
