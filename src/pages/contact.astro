---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/content';

const settings = await getSiteSettings();
---

<BaseLayout title="Contact" description="How families can reach Mr. Sayers through ClassDojo at Eshelman Elementary School.">
	<section class="panel section prose">
		<p class="eyebrow">Contact</p>
		<h2 class="page-title">Contact Mr. Sayers</h2>
		<p class="page-intro">
			{settings.contactNote ||
				'Eshelman Elementary School uses ClassDojo for classroom communication. Families should use ClassDojo to send messages to Mr. Sayers, receive classroom announcements, and stay informed about important reminders and updates.'}
		</p>
		<div class="contact-callout">
			<a class="button primary" href="https://www.classdojo.com/" target="_blank" rel="noreferrer">
				Open ClassDojo
			</a>
			<p class="fineprint">Opens in a new tab.</p>
		</div>
		<div class="grid cards">
			<article class="card">
				<h4>Use ClassDojo for</h4>
				<p>Classroom questions, student-related communication, reminders, and updates.</p>
			</article>
			<article class="card">
				<h4>Website focus</h4>
				<p>This site will share calendar information, weekly learning, and published classroom resources.</p>
			</article>
			<article class="card">
				<h4>Privacy note</h4>
				<p>Please avoid posting private contact details here. Personal email is not displayed publicly on this page.</p>
			</article>
		</div>
	</section>
</BaseLayout>
