{
	"compatibility_date": "2026-06-01",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "class-edthings",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"d1_databases": [
		{
			"binding": "CLASS_DB",
			"database_name": "class-edthings-db",
			"database_id": "80912867-7b6d-4672-8286-9523f21af3ef"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "7a4915f8fba145ebafb702dd61f795e3"
		}
	],
	"r2_buckets": [
		{
			"binding": "WORKSHEETS_BUCKET",
			"bucket_name": "class-edthings-worksheets"
		}
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
